{
  "compilerOptions": {
    /* ============================================
     * Базовые настройки компилятора
     * =========================================== */
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    
    /* ============================================
     * Строгость проверки типов
     * =========================================== */
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "useUnknownInCatchVariables": true,
    "exactOptionalPropertyTypes": true,
    
    /* ============================================
     * Настройки путей и модулей
     * =========================================== */
    "baseUrl": "./",
    "paths": {
      "@/*": ["./app/frontend/*"],
      "@app/*": ["./app/frontend/app/*"],
      "@components/*": ["./app/frontend/components/*"],
      "@pages/*": ["./app/frontend/pages/*"],
      "@assets/*": ["./app/frontend/assets/*"],
      "@styles/*": ["./app/frontend/styles/*"],
      "@utils/*": ["./app/frontend/utils/*"],
      "@hooks/*": ["./app/frontend/hooks/*"],
      "@lib/*": ["./app/frontend/lib/*"],
      "@server/*": ["./app/backend/*"],
      "@api/*": ["./app/backend/api/*"],
      "@shared/*": ["./shared/*"],
      "@config/*": ["./config/*"],
      "@tests/*": ["./tests/*"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    "checkJs": false,
    
    /* ============================================
     * Дополнительные настройки
     * =========================================== */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "sourceMap": true,
    "declaration": false,
    "declarationMap": false,
    "inlineSources": true,
    "inlineSourceMap": false,
    "removeComments": false,
    "types": ["vite/client", "@types/node"]
  },
  
  /* ============================================
   * Включение/исключение файлов
   * =========================================== */
  "include": [
    "app/frontend/**/*.ts",
    "app/frontend/**/*.tsx",
    "app/backend/**/*.ts",
    "shared/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx"
  ],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.server.json" }
  ]
}
