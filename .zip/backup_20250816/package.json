{
  "name": "wb-calculator",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "scripts": {
    "preinstall": "npx npm-force-resolutions",
    "path": "bash app/core/utils/where_i.sh",
    "dev": "vite",
    "dev:server": "tsx watch --clear-screen=false --no-warnings server/index.ts",
    "dev:all": "concurrently -k -n CLIENT,SERVER -c green,cyan \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:all": "npm run build && npm run build:server",
    "preview": "vite preview --port 4000",
    "start": "NODE_ENV=production node dist/server/index.js",
    "db:check": "tsx scripts/check-db-connection.ts",
    "db:init": "tsx scripts/init-db.ts",
    "db:migrate": "typeorm-ts-node-esm migration:run -d config/database.ts",
    "db:migrate:generate": "typeorm-ts-node-esm migration:generate -d config/database.ts",
    "db:migrate:revert": "typeorm-ts-node-esm migration:revert -d config/database.ts",
    "db:migrate:show": "typeorm-ts-node-esm migration:show -d config/database.ts",
    "db:seed": "tsx server/db/seed/index.ts",
    "db:seed:products": "npm run db:seed products",
    "db:clean": "npm run db:seed clean",
    "db:reset": "npm run db:clean && npm run db:migrate && npm run db:seed:products",
    "db:status": "npm run db:check",
    "db:test": "tsx scripts/test-connection.ts",
    "db:backup": "node scripts/db-utils.js backup",
    "db:exec": "node scripts/db-utils.js exec",
    "test:e2e": "playwright test",
    "update-imports": "tsx scripts/update-imports.ts"
  },
