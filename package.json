{
  "name": "wb-calculator",
  "private": true,
  "type": "module",
  "module": "ESNext",
  "main": "app.ts",
  "scripts": {
    "preinstall": "npx npm-force-resolutions",
    "path": "bash src/core/utils/where_i.sh",
    "build": "tsc && vite build",
    "dev": "tsx watch --clear-screen=false --no-warnings app.ts",
    "start": "node dist/bundle.js",
    "server": "node app/server/server.js",
    "frontend": "vite --port 4000",
    "wait": "wait-on tcp:3000",
    "dev:all": "npx kill-port 3000 3001 4000 && concurrently -k -n BACKEND,FRONTEND -c green,cyan \"npm run dev\" \"npm run wait && npm run frontend\"",
    "db:check": "tsx scripts/check-db.ts",
    "db:migrate": "typeorm-ts-node-commonjs migration:run -d ormconfig.ts",
    "db:migrate:generate": "typeorm-ts-node-commonjs migration:generate -d ormconfig.ts",
    "db:migrate:revert": "typeorm-ts-node-commonjs migration:revert -d ormconfig.ts",
    "db:migrate:show": "typeorm-ts-node-commonjs migration:show -d ormconfig.ts",
    "db:seed": "tsx src/db/seed/index.ts",
    "db:seed:products": "npm run db:seed products",
    "db:clean": "npm run db:seed clean",
    "db:reset": "npm run db:clean && npm run db:migrate && npm run db:seed:products",
    "db:backup": "node scripts/db-utils.js backup",
    "db:exec": "node scripts/db-utils.js exec",
    "db:status": "tsx scripts/check-db.ts",
    "db:init": "ts-node -r tsconfig-paths/register src/db/init.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
