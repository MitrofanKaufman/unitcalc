# Настройки базы данных MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_NAME=wb_calculator

# Настройки приложения
NODE_ENV=development
PORT=3000

# Настройки API Wildberries
WB_API_KEY=your_wb_api_key
WB_API_URL=https://suppliers-api.wildberries.ru

# Настройки сессии
SESSION_SECRET=your_session_secret

# Настройки кэширования
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Настройки логов
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_DIR=logs

# Настройки CORS
CORS_ORIGIN=http://localhost:4000

# Настройки безопасности
RATE_LIMIT_WINDOW_MS=900000  // 15 минут
RATE_LIMIT_MAX=100  // Максимальное количество запросов за окно

# Настройки WebSocket
WS_PORT=3001

# Настройки загрузки файлов
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  // 10MB

# Настройки почты (опционально)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
SMTP_FROM=noreply@example.com
